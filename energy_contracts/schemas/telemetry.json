{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/telemetry.json",
  "title": "Telemetry",
  "description": "설비 텔레메트리 — EdgeAgent→GridBridge (MQTT 5분 주기).",
  "_usage": "runtime-validate",
  "_consumers": [
    "edge-agent",
    "gridbridge"
  ],
  "version": "1.0",
  "type": "object",
  "required": [
    "ven_id",
    "timestamp",
    "power_kw"
  ],
  "properties": {
    "ven_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "power_kw": {
      "type": "number",
      "description": "현재 전력 소비 (kW)"
    },
    "indoor_temp_c": {
      "type": "number",
      "description": "실내 온도 (°C)"
    },
    "hvac_setpoint_c": {
      "type": "number",
      "description": "에어컨 설정 온도 (°C)"
    },
    "lighting_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "조명 디밍 (%)"
    },
    "ess_soc_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "ESS 충전률 (%)"
    },
    "ess_discharge_kw": {
      "type": "number",
      "description": "ESS 방전량 (kW)"
    },
    "active_strategy": {
      "type": "string",
      "description": "현재 실행 중인 EMS 전략 ID"
    },
    "schedule_slot_idx": {
      "type": "integer",
      "description": "현재 실행 중인 스케줄 슬롯 인덱스"
    },
    "mode": {
      "type": "string",
      "enum": [
        "prod",
        "demo",
        "dev",
        "test"
      ],
      "description": "EdgeAgent 운영 모드 audit 표시 (informational only — trust anchor 아님). Trust anchor는 bootstrap channel: ① mTLS 인증서의 mode extension OR ② GridBridge가 발급한 short-lived signed token에 mode embed. payload의 mode 단독 검증 금지 (위변조 가능). startup_check 는 bootstrap channel과 본 필드 일치 확인 — 5분 후 불일치 시 venue suspend + alert."
    },
    "mode_locked": {
      "type": "boolean",
      "description": "첫 telemetry에서 lock 후 mode 변경 시 alert + suspend (변조 탐지)."
    }
  }
}
