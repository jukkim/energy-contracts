{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/ems_strategies.json",
  "title": "EMS Strategies",
  "description": "EMS 전략 코드 SSOT (M00~M20). M00~M20=시뮬 EMS(NAMING §1.1), M16~M20=DR 제어 액션. ADR-EMS-NAMESPACE-UNIFY. 모든 모듈은 이 정의를 참조.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "3.0",
  "$defs": {
    "StrategyCode": {
      "type": "string",
      "enum": [
        "M00",
        "M01",
        "M02",
        "M03",
        "M04",
        "M05",
        "M06",
        "M07",
        "M08",
        "M09",
        "M10",
        "M11",
        "M12",
        "M13",
        "M14",
        "M15",
        "M16",
        "M17",
        "M18",
        "M19",
        "M20"
      ],
      "description": "통일 EMS 전략 코드 (21종, M00~M20). M00~M20=시뮬 EMS(NAMING §1.1), M16~M20=DR 제어 액션(ADR-EMS-NAMESPACE-UNIFY)."
    }
  },
  "type": "object",
  "properties": {
    "strategies": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/StrategyCode"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name_en": {
            "type": "string"
          },
          "name_kr": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "single",
              "combined"
            ],
            "description": "단일 전략 vs 복합 전략"
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/StrategyCode"
            },
            "description": "복합 전략의 구성 요소 (single은 빈 배열)"
          }
        },
        "required": [
          "name_en",
          "name_kr",
          "type",
          "components"
        ]
      }
    },
    "signal_mapping": {
      "type": "object",
      "description": "DR SignalLevel → 기본 전략 매핑 (flat, fallback). dr_type 컨텍스트 없을 때 사용.",
      "properties": {
        "NORMAL": {
          "$ref": "#/$defs/StrategyCode"
        },
        "MODERATE": {
          "$ref": "#/$defs/StrategyCode"
        },
        "HIGH": {
          "$ref": "#/$defs/StrategyCode"
        },
        "EMERGENCY": {
          "$ref": "#/$defs/StrategyCode"
        }
      }
    },
    "signal_mapping_dr": {
      "type": "object",
      "description": "DR SignalLevel → 전략 매핑, dr_type별 분기 (Phase 4 도입). esg_policy.dr_type ∈ {reliability,economic,both} 시 사용. 4 SignalLevel × 2 dr_type = 8 키 모두 필수. Fallback 체인: signal_mapping_dr.{level}.{type} 정의 누락 시 → signal_mapping_dr.{level}.reliability (보수적 가정) → signal_mapping.{level} (flat) → M00. dr_agent loader가 startup 시 8 키 모두 존재 검증.",
      "required": [
        "NORMAL",
        "MODERATE",
        "HIGH",
        "EMERGENCY"
      ],
      "properties": {
        "NORMAL": {
          "type": "object",
          "required": [
            "reliability",
            "economic"
          ],
          "properties": {
            "reliability": {
              "$ref": "#/$defs/StrategyCode"
            },
            "economic": {
              "$ref": "#/$defs/StrategyCode"
            }
          },
          "additionalProperties": false
        },
        "MODERATE": {
          "type": "object",
          "required": [
            "reliability",
            "economic"
          ],
          "properties": {
            "reliability": {
              "$ref": "#/$defs/StrategyCode"
            },
            "economic": {
              "$ref": "#/$defs/StrategyCode"
            }
          },
          "additionalProperties": false
        },
        "HIGH": {
          "type": "object",
          "required": [
            "reliability",
            "economic"
          ],
          "properties": {
            "reliability": {
              "$ref": "#/$defs/StrategyCode"
            },
            "economic": {
              "$ref": "#/$defs/StrategyCode"
            }
          },
          "additionalProperties": false
        },
        "EMERGENCY": {
          "type": "object",
          "required": [
            "reliability",
            "economic"
          ],
          "properties": {
            "reliability": {
              "$ref": "#/$defs/StrategyCode"
            },
            "economic": {
              "$ref": "#/$defs/StrategyCode"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "legacy_mapping": {
      "type": "object",
      "description": "구 코드 → 통일 코드 매핑 (읽기 전용, 신규 작성 금지)",
      "properties": {
        "ems_simulation": {
          "type": "object"
        },
        "gcs_e_codes": {
          "type": "object"
        },
        "ems_transformer_sc": {
          "type": "object"
        }
      }
    }
  },
  "default": {
    "strategies": {
      "M00": {
        "name_en": "Baseline",
        "name_kr": "고정 설정온도 + 야간 Setback",
        "type": "single",
        "components": []
      },
      "M01": {
        "name_en": "ScheduleOpt",
        "name_kr": "최적 기동·정지 (OptimalStart+EarlyStop)",
        "type": "single",
        "components": []
      },
      "M02": {
