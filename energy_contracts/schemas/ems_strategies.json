        "name_kr": "야간 순환 (NightCycle)",
        "type": "single",
        "components": []
      },
      "M07": {
        "name_en": "DCV",
        "name_kr": "CO2 수요제어환기",
        "type": "single",
        "components": []
      },
      "M08": {
        "name_en": "HeatRecovery",
        "name_kr": "전열교환기 (ERV)",
        "type": "single",
