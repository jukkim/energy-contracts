{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/hvac_ems_matrix.json",
  "title": "HvacEmsCompatibilityMatrix",
  "description": "HVAC type × EMS strategy 호환성 매트릭스 SSOT. F14 Policy Evaluation 의 G-PE1 validation 단계에서 infeasible 조합 차단에 사용. KOREAN_HVAC.md §13 + EMS_STRATEGY.md §21 EXPECTED_SKIP + SPEC_HVAC_SYSTEMS.md §3 통합.",
  "_usage": "runtime-validate",
  "_consumers": [
    "ems_transformer",
    "reverse",
    "mpc_model",
    "sim_campaign_2026"
  ],
  "version": "1.0.0",
  "updated": "2026-05-29",
  "$comment": "Phase 1.3 산출. SPEC_POLICY_VECTOR.md §2.2 가 본 매트릭스를 import. cell 값 의미: compatible (정상 적용) / marginal (적용 가능 but 절감 < 5%, warn) / infeasible (G-PE1 422 STRATEGY_INFEASIBLE_FOR_HVAC) / expected_skip (EMS_STRATEGY §21, infeasible 의 subset).",
  "type": "object",
  "required": ["hvac_types", "ems_strategies", "matrix"],
  "additionalProperties": false,
  "properties": {
    "hvac_types": {
      "type": "object",
      "description": "ASHRAE 901 STD2019 5 종 (A~E) + 한국화 4 종 (HD~HG)",
      "additionalProperties": false,
      "properties": {
        "A": {"const": "Central chilled water + boiler (chiller multi-stage)"},
        "B": {"const": "Packaged DX (split / rooftop, 1~2 stage)"},
        "C": {"const": "Single zone DX (residential / small commercial)"},
        "D": {"const": "VRF (inverter-driven multi-zone)"},
        "E": {"const": "Hydronic radiant + DOAS"},
        "HD": {"const": "Korean — VRF + 온돌 (residential 한국화)"},
        "HE": {"const": "Korean — 온돌 + gas boiler + PTAC (mid-rise residential)"},
        "HF": {"const": "Korean — Hybrid (central + 온돌)"},
        "HG": {"const": "Korean — gas-fired boiler + radiator (older retrofit)"}
      }
    },
    "ems_strategies": {
      "type": "object",
      "description": "M00~M15 EMS 전략 (ems_strategies.json#StrategyCode SSOT 참조)",
      "$ref": "ems_strategies.json#/$defs/StrategyCode"
    },
    "matrix": {
      "type": "object",
      "description": "key = HVAC type (A~E, HD~HG), value = { strategy_id: compatibility }. compatibility ∈ {compatible, marginal, infeasible, expected_skip}.",
      "additionalProperties": false,
      "properties": {
        "A": {"$ref": "#/$defs/StrategyRow"},
        "B": {"$ref": "#/$defs/StrategyRow"},
        "C": {"$ref": "#/$defs/StrategyRow"},
        "D": {"$ref": "#/$defs/StrategyRow"},
        "E": {"$ref": "#/$defs/StrategyRow"},
        "HD": {"$ref": "#/$defs/StrategyRow"},
        "HE": {"$ref": "#/$defs/StrategyRow"},
        "HF": {"$ref": "#/$defs/StrategyRow"},
        "HG": {"$ref": "#/$defs/StrategyRow"}
      }
    }
  },
  "$defs": {
    "Compatibility": {
      "type": "string",
      "enum": ["compatible", "marginal", "infeasible", "expected_skip"],
      "description": "compatible = 정상 / marginal = 절감 <5% warn / infeasible = 422 차단 / expected_skip = EMS §21 알려진 skip"
    },
    "StrategyRow": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^M(0[0-9]|1[0-5])$": {
          "type": "object",
          "required": ["compatibility"],
          "properties": {
            "compatibility": {"$ref": "#/$defs/Compatibility"},
            "expected_saving_pct_range": {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 2,
              "maxItems": 2,
              "description": "[min, max] %. infeasible 시 omit."
            },
            "note": {"type": "string"}
          }
        }
      }
    }
  },
  "default": {
