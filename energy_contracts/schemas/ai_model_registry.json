{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/ai_model_registry.json",
  "title": "AI Model Registry SSOT (Phase I-1)",
  "description": "8.simulation 13종 AI 모델 카탈로그 — Korean_BB, ems_transformer, building_ai 7종, factory_ai 13 등. 카르테 UI · 모델 마켓플레이스 · API /models/list SSOT.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$comment": "Phase I-1 산출물. data_classification.json#/$defs/DataSource 참조.",
  "$defs": {
    "ModelTask": {
      "type": "string",
      "enum": [
        "forecast",
        "anomaly",
        "predict",
        "classify",
        "rul",
        "optimize",
        "diagnose"
      ]
    },
    "ModelFramework": {
      "type": "string",
      "enum": [
        "xgboost",
        "lightgbm",
        "patchtst",
        "transformer",
        "isolation_forest",
        "lstm_autoencoder",
        "sklearn",
        "prophet",
        "tabnet",
        "energyplus"
      ]
    },
    "ModelEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "task",
        "framework"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "string"
        },
        "name_kr": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "체크포인트 상대 경로 (workspace root 기준)"
        },
        "task": {
          "$ref": "#/$defs/ModelTask"
        },
        "framework": {
          "$ref": "#/$defs/ModelFramework"
        },
        "input_shape": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "output_shape": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "accuracy_metric": {
          "type": "object",
          "description": "지표명 → 값. 예: {nrmse_pct: 12.3, mae: 0.05, f1: 0.92}",
          "additionalProperties": {
            "type": "number"
          }
        },
        "data_source": {
          "type": "string",
          "enum": [
            "measured",
            "certified",
            "simulated",
            "predicted",
            "external",
            "synthetic",
            "mock"
          ]
        },
        "trained_at": {
          "type": "string",
          "format": "date"
        },
        "frozen": {
          "type": "boolean",
          "default": false,
          "description": "true 시 변경 금지 (논문 투고·인증 중)"
        },
        "project": {
          "type": "string",
          "description": "8.simulation 하위 폴더"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "properties": {
    "models": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ModelEntry"
      }
    }
  },
  "default": {
    "models": {
