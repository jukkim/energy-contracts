{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/ai_model_registry.json",
  "title": "AI Model Registry SSOT (Phase I-1)",
  "description": "8.simulation 13종 AI 모델 카탈로그 — Korean_BB, ems_transformer, building_ai 7종, factory_ai 13 등. 카르테 UI · 모델 마켓플레이스 · API /models/list SSOT.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.1",
  "updated": "2026-05-20",
  "$comment": "Phase I-1 산출물 + AI 챔피언 본선 hash freeze (PRD v1.5 Track 3 G0). v1.1 = active_checkpoint + sha256 + frozen_for_demo 신설.",
  "$defs": {
    "ModelTask": {
      "type": "string",
      "enum": [
        "forecast",
        "anomaly",
        "predict",
        "classify",
        "rul",
        "optimize",
        "diagnose"
      ]
    },
    "ModelFramework": {
      "type": "string",
      "enum": [
        "xgboost",
        "lightgbm",
        "patchtst",
        "transformer",
        "isolation_forest",
        "lstm_autoencoder",
        "sklearn",
        "prophet",
        "tabnet",
        "energyplus"
      ]
    },
    "ModelEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "task",
        "framework"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "string"
        },
        "name_kr": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "체크포인트 상대 경로 (workspace root 기준)"
        },
        "task": {
          "$ref": "#/$defs/ModelTask"
        },
        "framework": {
          "$ref": "#/$defs/ModelFramework"
        },
        "input_shape": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "output_shape": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "accuracy_metric": {
          "type": "object",
          "description": "지표명 → 값. 예: {nrmse_pct: 12.3, mae: 0.05, f1: 0.92}",
          "additionalProperties": {
            "type": "number"
          }
        },
        "data_source": {
          "type": "string",
          "enum": [
            "measured",
            "certified",
            "simulated",
            "predicted",
            "external",
            "synthetic",
            "mock"
          ]
        },
        "trained_at": {
          "type": "string",
          "format": "date"
        },
        "frozen": {
          "type": "boolean",
          "default": false,
          "description": "true 시 변경 금지 (논문 투고·인증 중)"
        },
        "project": {
          "type": "string",
          "description": "8.simulation 하위 폴더"
        },
        "description": {
          "type": "string"
        },
        "active_checkpoint": {
          "type": "string",
          "description": "v1.1 추가 — 백엔드 health response 의 checkpoint 식별자와 매칭. Gateway startup_check 가 검증 (mismatch 시 startup ERROR). PRD v1.5 Track 3 G0."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "v1.1 추가 — 모델 파일 sha256. 선택 사항 (active_checkpoint name 매칭 우선)."
        },
        "backend_url": {
          "type": "string",
          "description": "v1.1 추가 — 백엔드 base URL (예: http://localhost:8040). Gateway adapter 가 호출."
        },
        "retrain_type": {
          "type": "string",
          "enum": ["type_1_sim", "type_2_real"],
          "description": "v1.1 추가 — Type 1(시뮬 학습, 수동만) vs Type 2(실측, 자동 가능). UNIFIED_GATEWAY_DESIGN §8.5."
        }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "properties": {
    "models": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ModelEntry"
      }
    },
    "frozen_for_demo": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "v1.1 추가 — 본선 시연용 freeze 모델 ID 목록. 본선 시점 Release Bundle manifest 가 이 목록을 참조. PRD v1.5 §4.2 + Track 3 G0. Gateway startup_check 가 이 모델들의 active_checkpoint 일치를 강제 검증."
    },
    "gateway_verify_policy": {
      "type": "string",
      "enum": ["strict", "warn", "off"],
      "default": "warn",
      "description": "v1.1 추가 — Gateway startup_check 의 검증 정책. strict=ERROR 차단, warn=alert 후 통과, off=비활성. 본선 시점 = strict, 개발 = warn."
    }
  },
