{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/reduction_schedule.json",
  "title": "ReductionSchedule",
  "description": "감축 스케줄 — N일간 시간대별 절감 계획. VWorld→GridBridge/EdgeAgent 전달.",
  "_usage": "runtime-validate",
  "_consumers": [
    "edge-agent",
    "gridbridge"
  ],
  "version": "1.0",
  "type": "object",
  "required": [
    "days"
  ],
  "properties": {
    "schedule_id": {
      "type": "string",
      "description": "스케줄 고유 ID"
    },
    "name": {
      "type": "string",
      "description": "스케줄 이름"
    },
    "ven_id": {
      "type": "string",
      "description": "대상 VEN (경로2: 개별)"
    },
    "group_id": {
      "type": "string",
      "description": "대상 ESG 그룹 (경로1: 그룹)"
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/DailySchedule"
      }
    },
    "recurrence": {
      "type": "string",
      "enum": [
        "none",
        "daily",
        "weekdays",
        "weekly",
        "monthly"
      ]
    },
    "created_by": {
      "type": "string",
      "default": "system"
    },
    "source": {
      "type": "string",
      "enum": [
        "vworld",
        "gridbridge",
        "auto"
      ]
    }
  },
  "$defs": {
    "DailySchedule": {
      "type": "object",
      "required": [
        "date",
        "slots"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "YYYY-MM-DD"
        },
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ReductionSlot"
          }
        }
      }
    },
    "ReductionSlot": {
      "type": "object",
      "required": [
        "start_time",
        "end_time",
        "reduction_kw"
      ],
      "properties": {
        "start_time": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "end_time": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "reduction_kw": {
          "type": "number",
          "minimum": 0
        },
        "strategy": {
          "type": "string",
          "pattern": "^M(0[0-9]|1[0-9]|20)$",
          "description": "EMS 전략 ID (M00~M20)"
        },
        "constraints": {
          "type": "object",
          "description": "{max_temp, min_lighting, ...}"
        },
        "condition": {
          "type": "object",
          "description": "활성화 조건 {smp_above, temp_above}"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 1
        }
      }
    }
  }
}
