{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/ui_capabilities.json",
  "title": "UI Capabilities (Frontend Capability Contract)",
  "description": "F14형 유계 UI 능력 계약 SSOT. 자연어를 '생성'이 아니라 '분류·라우팅'으로 매핑할 대상(bounded target)을 정의한다. 재학습 불요 — 각 능력은 기존 F-route 라우팅 / 기학습 LoRA / scene op replay 로 실행. gateway_routing.json(백엔드 능력 F1~F14)의 프론트엔드 대칭 레지스트리.",
  "_usage": "reference-only",
  "_consumers": [
    "building-energy-3d",
    "energy-decision-studio",
    "energy-decision-canvas"
  ],
  "version": "1.0",
  "updated": "2026-07-01",
  "$comment": "Producer 참조(재정의·복제 금지 — producer/mirror 규율): lever_id enum = agentleague policy_levers.py LEVER_CATALOG(22, producer SSOT); M-code = ems_strategies.json(M00~M20); IntentType = nl_intents.json; F-route = gateway_routing.json. 상세 열거·M-code 교차검증 = 공모전/2026-04-24_AI챔피언/docs/UI_CAPABILITY_ENUMERATION.md. 계획 = docs/UI_CAPABILITY_CONTRACT_AND_NL_ROUTER_PLAN.md. reference-only → gen_constants.load_schemas() 미연결(cascade 0).",
  "$defs": {
    "UICapabilityId": {
      "type": "string",
      "enum": [
        "ui.apply_policy_lever",
        "ui.identify_ems",
        "ui.recommend_retrofit",
        "ui.forecast_24h",
        "ui.counterfactual",
        "ui.report_qa",
        "ui.run_debate",
        "ui.choropleth_map",
        "ui.timeline",
        "ui.zoom_ladder",
        "ui.select_buildings",
        "ui.policy_cascade"
      ],
      "description": "유계 UI 원자 기능 12종. 시퀀스(seq.*)는 sequences 에 별도 정의."
    },
    "CapabilityCategory": {
      "type": "string",
      "enum": ["policy_control", "diagnosis", "visualization"],
      "description": "능력 범주. 흐름(flow)은 sequences 로 표현."
    },
    "BindingLayer": {
      "type": "string",
      "enum": ["f_route", "m_code_lever", "scene_op", "lora_qa", "lora_debate"],
      "description": "실행 계층. f_route=Gateway F-route 라우팅 / m_code_lever=F14+22레버(M-code) / scene_op=op_registry replay / lora_qa=기학습 QA LoRA① / lora_debate=기학습 policy LoRA②. 전부 신규 학습 불요."
    },
    "RoutingTier": {
      "type": "string",
      "enum": ["tier0_template", "tier1_function", "tier2_confirm", "tier3_compose"],
      "description": "NL 라우터 4-tier 사다리. tier0=유계 시퀀스 정확매치 / tier1=단일기능+param추출 / tier2=퍼지→확인UI / tier3=compose 폴백(LoRA③)."
    }
  },
  "type": "object",
  "properties": {
    "capabilities": {
      "type": "object",
      "description": "UICapabilityId → 능력 정의.",
      "propertyNames": { "$ref": "#/$defs/UICapabilityId" },
      "additionalProperties": {
        "type": "object",
        "required": ["label_ko", "category", "binding_layer", "primary_tier"],
        "properties": {
          "label_ko": { "type": "string", "description": "쉬운 한국어 라벨(약어 지양·전문용어 괄호 풀이)" },
          "category": { "$ref": "#/$defs/CapabilityCategory" },
          "binding_layer": { "$ref": "#/$defs/BindingLayer" },
          "backend": { "type": "string", "description": "바인딩 대상(F-route 코드 / op 이름 / 서비스). gateway_routing.json·op_registry.json 참조." },
          "params": {
            "type": "object",
            "description": "param 이름 → {type, range|enum_ref, required}. 값 범위·enum 은 producer SSOT 참조(EC 재정의 금지).",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "enum_ref": { "type": "string", "description": "enum producer 위치(예: policy_levers.py LEVER_CATALOG)" },
                "range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
                "unit": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "composition_ok": { "type": "boolean", "description": "순차 조합(시퀀스 스텝) 가능 여부" },
          "primary_tier": { "$ref": "#/$defs/RoutingTier" },
          "requires_training": { "type": "boolean", "description": "신규 학습 필요 여부(전부 false — F14형 원칙)" },
          "note": { "type": "string" }
        }
      }
    },
    "sequences": {
      "type": "object",
      "description": "유계 시퀀스 템플릿(Tier 0). 데모 필수 연출은 고정 op/기능 배열 replay 로 compose 우회(항상 동작).",
      "additionalProperties": {
        "type": "object",
        "required": ["label_ko", "steps"],
        "properties": {
          "label_ko": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "string" }, "description": "UICapabilityId 순서 배열" },
          "note": { "type": "string" }
        }
      }
    }
  },
  "default": {
    "capabilities": {
      "ui.apply_policy_lever": {
        "label_ko": "정책 적용(레버 선택 + 값 조정)",
        "category": "policy_control",
        "binding_layer": "m_code_lever",
        "backend": "F14 /v1/policy-evaluate (fast) → KBEP",
        "params": {
          "lever_id": { "type": "string", "required": true, "enum_ref": "agentleague policy_levers.py LEVER_CATALOG (22)", "note": "candidate M-code=M00~M15 서브셋" },
          "lever_params": { "type": "object", "required": false, "note": "레버별 파라미터(범위=policy_levers.py POLICY_LEVERS[lever].params). param_sensitivity 정의 레버 7종은 Tier1 추출 우선" }
        },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false,
        "note": "NL→lever_id + param 바인딩이 라우터 핵심. 확신도 미달 시 확인 UI(슬라이더)."
      },
      "ui.identify_ems": {
        "label_ko": "이 건물 냉난방 운전방식 알아내기(역추정)",
        "category": "diagnosis",
        "binding_layer": "f_route",
        "backend": "F5 /v1/ems/diagnose (reverse)",
        "params": { "building_id": { "type": "string", "required": true } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.recommend_retrofit": {
        "label_ko": "절감 대책 추천(투자대비회수 순위)",
        "category": "diagnosis",
        "binding_layer": "f_route",
        "backend": "F7 /v1/ems/recommend (reverse)",
        "params": { "building_id": { "type": "string", "required": true }, "budget": { "type": "number", "required": false, "unit": "KRW" } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.forecast_24h": {
        "label_ko": "24시간 에너지 예측",
        "category": "diagnosis",
        "binding_layer": "f_route",
        "backend": "F4 /v1/forecast/24h (Korean_BB)",
        "params": { "building_id": { "type": "string", "required": true } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.counterfactual": {
        "label_ko": "다르게 운전하면(반사실) 얼마나 바뀌나",
        "category": "diagnosis",
        "binding_layer": "f_route",
        "backend": "F9 /v1/counterfactual (KBEP)",
        "params": { "building_id": { "type": "string", "required": true }, "strategy_id": { "type": "string", "required": true, "enum_ref": "ems_strategies.json M00~M20" } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.report_qa": {
        "label_ko": "자연어 진단·설명 리포트",
        "category": "diagnosis",
        "binding_layer": "lora_qa",
        "backend": "F1/F2 /v1/qa/* (Exaone QA LoRA①, 기학습)",
        "params": { "question": { "type": "string", "required": true } },
        "composition_ok": false,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.run_debate": {
        "label_ko": "다관점 토론(정책/실행 도메인)",
        "category": "diagnosis",
        "binding_layer": "lora_debate",
        "backend": "agentleague → Exaone ②policy(merged_unified, 기학습)",
        "params": {
          "debate_type": { "type": "string", "required": true },
          "domain": { "type": "string", "required": false, "enum_ref": "policy|execution (DEBATE_DOMAIN_TAXONOMY)" },
          "personas": { "type": "array", "required": false, "note": "1~3, personas.py 8종" }
        },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.choropleth_map": {
        "label_ko": "지역별 현황 지도 색칠",
        "category": "visualization",
        "binding_layer": "scene_op",
        "backend": "op:mountMetricChoropleth (학습됨)",
        "params": { "metric": { "type": "string", "required": true }, "region": { "type": "string", "required": false } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.timeline": {
        "label_ko": "연도별 변화 타임라인",
        "category": "visualization",
        "binding_layer": "scene_op",
        "backend": "op:mountMetricTimeline (학습됨)",
        "params": { "metric": { "type": "string", "required": true }, "yearA": { "type": "number", "required": false }, "yearB": { "type": "number", "required": false } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.zoom_ladder": {
        "label_ko": "전국→구→건물 사다리 줌",
        "category": "visualization",
        "binding_layer": "scene_op",
        "backend": "op:mountLadderDemo 시퀀스",
        "params": { "region": { "type": "string", "required": false } },
        "composition_ok": true,
        "primary_tier": "tier0_template",
        "requires_training": false,
        "note": "⚠️ compose 학습 0회 op → Tier 0 유계 시퀀스로 고정(compose 생성 금지, silent no-op 방지)."
      },
      "ui.select_buildings": {
        "label_ko": "건물 선택(집합)",
        "category": "visualization",
        "binding_layer": "scene_op",
        "backend": "op:selectBuildings",
        "params": { "filter": { "type": "object", "required": false }, "as": { "type": "string", "required": false, "note": "register 이름(데이터 흐름 source)" } },
        "composition_ok": true,
        "primary_tier": "tier1_function",
        "requires_training": false
      },
      "ui.policy_cascade": {
        "label_ko": "정책 캐스케이드 패널",
        "category": "visualization",
        "binding_layer": "scene_op",
        "backend": "op:mountReverseCascade 시퀀스",
        "params": { "region": { "type": "string", "required": false } },
        "composition_ok": true,
        "primary_tier": "tier0_template",
        "requires_training": false,
        "note": "⚠️ compose 학습 0회 op → Tier 0 고정 필수."
      }
    },
    "sequences": {
      "seq.golden": {
        "label_ko": "강남 노후건물 절감 골든패스(60초)",
        "steps": ["ui.choropleth_map", "ui.zoom_ladder", "ui.apply_policy_lever", "ui.counterfactual"],
        "note": "데모 시그니처 — Tier 0 고정 replay."
      },
      "seq.compare": {
        "label_ko": "정책 비교(다중 레버)",
        "steps": ["ui.choropleth_map", "ui.apply_policy_lever", "ui.apply_policy_lever", "ui.report_qa"]
      },
      "seq.diagnose": {
        "label_ko": "한 건물 진단→처방→토론",
        "steps": ["ui.select_buildings", "ui.identify_ems", "ui.recommend_retrofit", "ui.run_debate"]
      }
    }
  }
}
