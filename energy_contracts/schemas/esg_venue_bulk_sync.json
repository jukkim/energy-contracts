{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://building-energy.xyz/schemas/esg_venue_bulk_sync.json",
  "title": "EsgVenueBulkSync",
  "description": "ESG 그룹 VEN 일괄 동기화. PUT /api/v1/gridbridge/esg/groups/{group_id}/venues (R14-8)",
  "_usage": "reference-only",
  "_consumers": [
    "gridbridge"
  ],
  "type": "object",
  "required": [
    "venue_ids"
  ],
  "properties": {
    "venue_ids": {
      "type": "array",
      "description": "그룹에 할당할 VEN ID 전체 목록 (멱등 — 기존 멤버와 diff하여 추가/제거)",
      "items": {
        "type": "string",
        "description": "VEN ID",
        "examples": [
          "VEN-STORE-B008",
          "VEN-STORE-B009"
        ]
      },
      "uniqueItems": true
    },
    "sync_mode": {
      "type": "string",
      "description": "동기화 모드",
      "enum": [
        "replace",
        "upsert"
      ],
      "default": "replace",
      "examples": [
        "replace"
      ]
    }
  },
  "definitions": {
    "BulkVenueSyncResponse": {
      "type": "object",
      "required": [
        "group_id",
        "added",
        "removed",
        "unchanged"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "description": "ESG 그룹 ID",
          "examples": [
            "ESG-PF-7"
          ]
        },
        "added": {
          "type": "array",
          "description": "새로 추가된 VEN ID 목록",
          "items": {
            "type": "string"
          }
        },
        "removed": {
          "type": "array",
          "description": "그룹에서 제거된 VEN ID 목록",
          "items": {
            "type": "string"
          }
        },
        "unchanged": {
          "type": "integer",
          "description": "변경 없는 기존 멤버 수"
        },
        "total": {
          "type": "integer",
          "description": "동기화 후 총 VEN 수"
        }
      }
    }
  },
  "examples": [
    {
      "venue_ids": [
        "VEN-STORE-B008",
        "VEN-STORE-B009",
        "VEN-STORE-B030",
        "VEN-STORE-B061",
        "VEN-STORE-RGR010533"
      ],
      "sync_mode": "replace"
    }
  ]
}
