{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/pipeline_status.json",
  "title": "Data Pipeline Status SSOT (Phase J-11)",
  "description": "데이터셋 입수·전처리 상태 추적. myjob/CLAUDE.md Shared Data Sources 표를 머신리더블화.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$defs": {
    "Stage": {
      "type": "string",
      "enum": [
        "raw",
        "downloaded",
        "normalized",
        "validated",
        "curated",
        "published",
        "frozen"
      ]
    },
    "DatasetEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "stage",
        "size_bytes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "string"
        },
        "stage": {
          "$ref": "#/$defs/Stage"
        },
        "size_bytes": {
          "type": "integer"
        },
        "row_count": {
          "type": "integer"
        },
        "path": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "data_source": {
          "type": "string",
          "description": "data_classification.json#/$defs/DataSource"
        },
        "updated": {
          "type": "string",
          "format": "date"
        },
        "frozen": {
          "type": "boolean",
          "default": false
        },
        "owner": {
          "type": "string"
        }
      }
    }
  },
  "type": "object",
