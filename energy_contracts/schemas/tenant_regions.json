{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/tenant_regions.json",
  "title": "Tenant Regions SSOT (Phase J-9)",
  "description": "한국 권역(Metro/Gangwon/...) + ASEAN 6 테넌트 + 인도네시아 12 도시 통합. 기존 region_codes.json(시뮬 C01~C11)을 보완. building-energy-id 6 테넌트 + GridBridge 권역 통합 SSOT.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$defs": {
    "RegionEntry": {
      "type": "object",
      "required": [
        "code",
        "name_kr",
        "name_en",
        "country"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z]{2}-[A-Z]{2,8}$"
        },
        "name_kr": {
          "type": "string"
        },
        "name_en": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2"
        },
        "timezone": {
          "type": "string"
        },
        "climate_zone": {
          "type": "string",
          "description": "ASHRAE 169"
        },
        "is_tropical": {
          "type": "boolean",
          "default": false
        },
        "parent_region": {
          "type": "string"
        }
      }
    }
  },
  "type": "object",
