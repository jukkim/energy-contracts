{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/agent_contracts.json",
  "title": "AgentContract SSOT (AI 챔피언 멀티에이전트)",
  "description": "A01~A10 에이전트 입출력 Protocol. building-energy-3d/src/agents/core/contract.py 와 동기. AI 챔피언 본선 카르테 시스템의 단일 진실.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$comment": "Phase C1 산출물 (myjob/docs/SSOT_GOVERNANCE.md). gen_constants.py 가 이 스키마를 Tier 3 코드로 자동 생성.",
  "$defs": {
    "BuildingContext": {
      "type": "object",
      "description": "에이전트 입력 — 건물 컨텍스트. A01(진단)이 PNU에서 생성, A03/A04/A07 등이 입력으로 받음.",
      "required": [
        "pnu",
        "address",
        "usage_type",
        "gross_area",
        "floors",
        "built_year",
        "structure",
        "eui",
        "energy_tier",
        "energy_grade"
      ],
      "properties": {
        "pnu": {
          "type": "string",
          "description": "법정 PNU 19자리"
        },
        "address": {
          "type": "string"
        },
        "usage_type": {
          "type": "string",
          "description": "건축물대장 용도. constants.py BUILDING_USAGE_MAP 참조"
        },
        "gross_area": {
          "type": "number",
          "description": "연면적 (m²)"
        },
        "floors": {
          "type": "integer"
        },
        "built_year": {
          "type": "integer"
        },
        "structure": {
          "type": "string"
        },
        "eui": {
          "type": "number",
          "description": "Energy Use Intensity (kWh/m²·yr)"
        },
        "energy_tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "data_tier (1=measured, 5=ep_lookup)"
        },
        "energy_grade": {
          "type": "string",
          "description": "1+~7 또는 ZEB 등급"
        },
        "has_kapt": {
          "type": "boolean",
          "default": false
        },
        "has_hourly": {
          "type": "boolean",
          "default": false
        },
        "has_fire_risk": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "AgentResult": {
      "type": "object",
      "description": "에이전트 출력 표준 — 카르테 카드/포트폴리오/SSE에 동일 형식.",
      "required": [
        "agent_name",
        "version",
        "confidence",
        "summary"
      ],
      "properties": {
        "agent_name": {
          "type": "string",
          "description": "예: 'a01_diagnosis'"
        },
        "version": {
          "type": "string",
          "description": "에이전트 버전 (semver)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "결과 신뢰도. 5-Tier 데이터 품질 기반 계산"
        },
        "summary": {
          "type": "string",
          "description": "한 문장 요약 (카드 헤더)"
        },
        "payload": {
          "type": "object",
          "description": "에이전트별 자유 형식 데이터",
          "default": {}
        },
        "method_used": {
          "type": "string",
          "description": "사용된 방법 라벨 (예: 'L0_template' / 'L2_llm')",
          "default": ""
        },
        "ml_model_version": {
          "type": [
            "string",
            "null"
          ],
          "description": "L1 ML 경로 시 모델 식별자 (예: 'patchtst_v5_168to24'). L0/룰 분기에서는 null.",
          "default": null
        },
        "elapsed_sec": {
          "type": "number",
          "minimum": 0,
          "description": "실행 시간 (초)",
          "default": 0.0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "error": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "BuildingForecast": {
      "type": "object",
      "description": "PNU → 168h 시계열 + 24h 예측. AI 챔피언 a02_forecast 의존성 (Phase D 마이그레이션 A). ems_transformer Gateway `/v1/building/forecast?pnu=` 가 본 모델로 응답.",
      "required": ["pnu", "forecast_24h_kw", "ml_model_version"],
      "properties": {
        "pnu": {
          "type": "string",
          "minLength": 19,
          "maxLength": 19
        },
        "context_168h_kw": {
          "type": ["array", "null"],
          "items": {"type": "number"},
          "description": "168h hourly 실측 (kW). 미보유 시 null — fixture/L0 fallback 분기 가능",
          "default": null
        },
        "forecast_24h_kw": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 24,
          "maxItems": 24,
          "description": "Korean_BB TwGauss-M 24h hourly 예측 (kW)"
        },
        "peak_kw_24h": {
          "type": "number",
          "minimum": 0,
          "default": 0.0
        },
        "avg_kw_24h": {
          "type": "number",
          "minimum": 0,
          "default": 0.0
        },
        "ml_model_version": {
          "type": "string",
          "description": "예: 'patchtst_v5_168to24_real' / 'patchtst_v5_168to24_synthetic'"
        },
        "timeseries_available": {
          "type": "boolean",
          "default": false,
          "description": "실측 168h 시계열 보유 여부. false 면 forecast 도 synthetic"
        }
      },
      "additionalProperties": false
    },
    "BenchmarkStats": {
      "type": "object",
      "description": "PNU+EUI → 같은 용도·연식 그룹 percentile + 공장 산업 컨텍스트. AI 챔피언 a07_benchmark 의존성. ems_transformer Gateway `/v1/building/benchmark?pnu=&eui=&usage_type=&built_year=` 응답.",
      "required": ["pnu", "available"],
      "properties": {
        "pnu": {"type": "string", "minLength": 19, "maxLength": 19},
        "available": {
          "type": "boolean",
          "description": "그룹 비교 가능 여부 (같은 그룹 ≥ 10개). false 면 a07 fallback (산업 컨텍스트만 있을 수 있음)"
        },
        "percentile": {"type": ["number", "null"], "default": null},
        "group_total": {"type": "integer", "minimum": 0, "default": 0},
        "group_avg_eui": {"type": ["number", "null"], "default": null},
        "q25": {"type": ["number", "null"], "default": null},
        "q75": {"type": ["number", "null"], "default": null},
        "rank": {
          "type": ["string", "null"],
          "description": "상위 우수 / 평균 이상 / 평균 이하 / 하위",
          "default": null
        },
        "target_eui": {"type": ["number", "null"], "default": null},
        "improvement_kwh": {"type": ["number", "null"], "default": null},
        "group_label": {
          "type": ["string", "null"],
          "description": "예: '업무시설 · 2011-2020'",
          "default": null
        },
        "industry_context": {
          "type": ["object", "null"],
          "description": "공장/제조에 한해 한국에너지공단 GHG 광역시도 평균. 비공장 null.",
          "default": null,
          "properties": {
            "region": {"type": "string"},
            "source": {"type": "string"},
            "year": {"type": ["integer", "null"]},
            "biz_count": {"type": "integer"},
            "avg_co2_ton_per_biz": {"type": "number"},
            "total_co2_ton": {"type": ["number", "null"]},
            "note": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "FireRiskAssessment": {
      "type": "object",
      "description": "PNU → building_fire_risk MV (7-component scoring) + inspection_obligation_active. AI 챔피언 a05_safety 의존성. ems_transformer Gateway `/v1/building/fire-risk?pnu=` 응답.",
      "required": ["pnu", "available"],
      "properties": {
        "pnu": {
          "type": "string",
          "minLength": 19,
          "maxLength": 19
        },
        "available": {
          "type": "boolean",
          "description": "MV 데이터 가용 여부. false 면 a05 rules 분기"
        },
        "structure_score": {"type": "integer", "minimum": 0, "default": 0},
        "age_score": {"type": "integer", "minimum": 0, "default": 0},
        "usage_score": {"type": "integer", "minimum": 0, "default": 0},
        "height_score": {"type": "integer", "minimum": 0, "default": 0},
        "disaster_zone_score": {"type": "integer", "minimum": 0, "default": 0},
        "history_score": {"type": "integer", "minimum": 0, "default": 0},
        "inspection_score": {"type": "integer", "minimum": 0, "default": 0},
        "total_score": {"type": "integer", "minimum": 0, "default": 0},
        "risk_grade": {
          "type": ["string", "null"],
          "description": "HIGH / MEDIUM / LOW",
          "default": null
        },
        "has_obligation": {"type": "boolean", "default": false},
        "obligation_source": {"type": ["string", "null"], "default": null},
        "obligation_confidence": {"type": ["string", "null"], "default": null},
        "obligation_type": {"type": ["string", "null"], "default": null}
      },
      "additionalProperties": false
    },
    "SetbackPattern": {
      "type": "object",
      "description": "PNU → 야간감축 setback 패턴 분류. AI 챔피언 a03_optimizer 의존성 (Phase D 마이그레이션). inverse_ems RF 분류기 결과. ems_transformer Gateway `/v1/building/setback-pattern?pnu=` 응답.",
      "required": ["pnu", "available"],
      "properties": {
        "pnu": {
          "type": "string",
          "minLength": 19,
          "maxLength": 19
        },
        "available": {
          "type": "boolean",
          "description": "분류 가능 여부 (실측 시계열 + 모델 가용). false 면 a03 가 rules 만 사용"
        },
        "label": {
          "type": ["string", "null"],
          "description": "예: 'SETBACK' / 'NO_SETBACK' / 'MIXED'",
          "default": null
        },
        "probability": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "default": null
        },
        "is_setback": {
          "type": "boolean",
          "default": false
        },
        "days_used": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "engine": {
          "type": ["string", "null"],
          "description": "예: 'rf_v1_168h_F1_0.911'",
          "default": null
        }
      },
      "additionalProperties": false
    },
    "AgentCapability": {
      "type": "string",
      "enum": [
        "diagnosis",
        "forecast",
        "optimization",
        "carbon",
        "safety",
        "renewable",
        "benchmark",
        "market",
        "policy",
        "coordination",
        "dr_orchestration"
      ],
      "description": "A01~A10 핵심 능력 + Phase 4 a11 dr_orchestration"
    },
    "MaturityLevel": {
      "type": "string",
      "enum": [
        "L0_template",
        "L1_rule",
        "L2_llm",
        "L3_optimization"
      ],
      "description": "에이전트 성숙도 (RQ-AI 프레임). L0=정적 템플릿, L1=규칙 기반, L2=LLM, L3=최적화 알고리즘"
    }
  },
  "type": "object",
  "properties": {
    "registry": {
      "type": "object",
      "description": "에이전트 카탈로그 (Phase 1~3: A01~A10, Phase 4+: A11~)",
      "additionalProperties": {
        "type": "object",
        "required": [
          "id",
          "name_en",
          "name_kr",
          "capability",
          "phase"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^a(0[1-9]|1[0-9]|2[0-9])$",
            "description": "a01~a29까지 허용 (Phase 4 a11 dr_orchestrator 도입)"
          },
          "name_en": {
            "type": "string"
          },
          "name_kr": {
            "type": "string"
          },
          "capability": {
            "$ref": "#/$defs/AgentCapability"
          },
          "phase": {
            "type": "integer",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ]
          },
          "maturity": {
            "$ref": "#/$defs/MaturityLevel"
          },
          "requires": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "선행 에이전트 ID (예: A03/A04/A07은 A01 필요)"
          },
          "output_strategies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^M(0[0-9]|1[0-5])$"
            },
            "description": "이 에이전트가 산출할 수 있는 EMS 전략 코드 (Phase H 추가). 비어있으면 전략을 산출하지 않음 (예: 진단·예측·벤치마크)."
          },
          "output_data_source": {
            "$ref": "energy-contracts/data_classification.json#/$defs/DataSource",
            "description": "이 에이전트 결과의 데이터 출처 분류 (Phase H 추가). measured/certified/simulated/predicted/external/synthetic/mock"
          }
        }
      }
    }
  },
