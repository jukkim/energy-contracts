{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/building_usage_map.json",
  "title": "Building Usage Map SSOT (Phase J-7)",
  "description": "건축물대장 용도 코드 ↔ archetype ↔ 에너지 사용패턴 매핑. 한국(729만 건물) + 인도네시아 BEMS(12.5M ASEAN 건물).",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$defs": {
    "UsageEntry": {
      "type": "object",
      "required": [
        "code",
        "name_kr",
        "name_en",
        "archetype"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "건축물대장 code (예: 02000)"
        },
        "name_kr": {
          "type": "string"
        },
        "name_en": {
          "type": "string"
        },
        "archetype": {
          "type": "string",
          "description": "EnergyPlus archetype 매핑"
        },
        "default_eui_kwh_m2": {
          "type": "number"
        },
        "energy_pattern": {
          "type": "object",
          "description": "에너지 사용 분담 (collect_energy.py _FRACS 호환)",
          "properties": {
            "heating": {
              "type": "number"
            },
            "cooling": {
              "type": "number"
            },
            "hot_water": {
              "type": "number"
            },
            "lighting": {
              "type": "number"
            },
            "ventilation": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "type": "object",
