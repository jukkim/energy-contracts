{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/data_classification.json",
  "title": "Data Classification SSOT (Phase F)",
  "description": "데이터 분류 2축 (출처 × 품질). building-energy-3d data_tier 호환 + 합성·외부·mock 카테고리 추가. 프로젝트는 extensions로 자체 카테고리 추가 가능.",
  "version": "1.0",
  "updated": "2026-05-17",
  "$comment": "myjob/docs/MODES_AND_DATA_RESEARCH.md §2.3 산출물.",

  "$defs": {
    "DataSource": {
      "type": "string",
      "enum": ["measured", "certified", "simulated", "predicted", "external", "synthetic", "mock"],
      "description": "출처 축. measured=실 계량, certified=공식 인증, simulated=시뮬 산출, predicted=ML 예측, external=외부 벤더, synthetic=합성/생성기, mock=의도적 모킹"
    },
    "DataTier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "품질 등급 1~5 (1=최고). building-energy-3d data_tier와 동일. synthetic/mock은 N/A로 표기 (별도 필드)"
    },
    "DataCategory": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"$ref": "#/$defs/DataSource"},
        "tier":   {"$ref": "#/$defs/DataTier"},
        "description": {"type": "string"},
        "example":     {"type": "string"},
        "is_runtime":  {"type": "boolean", "description": "true=운영 데이터, false=테스트 전용"}
      },
      "additionalProperties": true
    },
    "DataAvailability": {
      "type": "string",
      "enum": ["immediate", "synthetic_generator", "external_static", "pipeline_ingested"],
      "description": "테스트 데이터 가용성. immediate=conftest fixture, synthetic_generator=동적 생성, external_static=사전 다운로드 정적, pipeline_ingested=파이프라인 단계적 입수"
    },
    "PipelineStage": {
      "type": "string",
      "enum": ["raw", "downloaded", "normalized", "validated", "curated", "published"],
      "description": "파이프라인 입수 단계. raw→curated→published 진행"
    }
  },

  "type": "object",
  "properties": {
    "sources": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/DataSource"},
      "additionalProperties": {"$ref": "#/$defs/DataCategory"}
    },
    "tier_mapping": {
      "type": "object",
      "description": "building-energy-3d data_tier 호환 매핑"
    },
    "extensions": {
      "type": "object",
      "description": "프로젝트별 자체 카테고리 추가",
      "additionalProperties": true
    }
  },

  "default": {
    "sources": {
      "measured":  {"source": "measured",  "tier": 1, "description": "실 계량/관측",       "example": "KEPCO, GS25, ASOS, K-apt", "is_runtime": true},
      "certified": {"source": "certified", "tier": 2, "description": "공식 인증",          "example": "KEA, 건축물대장",         "is_runtime": true},
      "predicted": {"source": "predicted", "tier": 3, "description": "ML 예측",            "example": "Korean_BB, XGBoost",      "is_runtime": true},
      "simulated": {"source": "simulated", "tier": 4, "description": "시뮬 산출",          "example": "EnergyPlus 90건",         "is_runtime": true},
      "external":  {"source": "external",  "tier": 5, "description": "외부 벤더/공공",     "example": "Cesium 3D Tiles, VWorld API, data.go.kr", "is_runtime": true},
      "synthetic": {"source": "synthetic",             "description": "합성/생성기",       "example": "pytest fixtures, scenario gen", "is_runtime": false},
      "mock":      {"source": "mock",                  "description": "의도적 mock",       "example": "LLM stub, MQTT broker stub",    "is_runtime": false}
    },
    "tier_mapping": {
      "1_measured":     "source=measured,  tier=1",
      "2_certified":    "source=certified, tier=2",
      "3_ml_xgboost":   "source=predicted, tier=3",
      "4_ep_simulation":"source=simulated, tier=4",
      "5_ep_lookup":    "source=external,  tier=5  (또는 simulated, tier=5 if EP 사전계산)"
    },
    "extensions": {
      "building-energy-3d": {
        "energy_results_data_tier": "기존 1~5 컬럼 유지, source_type 컬럼이 source 축 매핑"
      },
      "agentleague": {
        "is_demo": "boolean 컬럼 — DEMO 모드 데이터 격리. source/tier와 독립 축"
      },
      "gridbridge": {
        "telemetry_kind": "live (48h 이내) vs demo (retain) — 시간 기반 자동 판별"
      }
    }
  }
}
