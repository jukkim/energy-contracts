{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/virtual_prosumer.json",
  "title": "VirtualProsumer",
  "description": "EnergyPlus 등으로 에뮬레이션되는 제어형 수용가의 I/O 계약. Edge 팀이 제공.",
  "version": "1.0",
  "type": "object",
  "required": ["ven_id", "backend", "observable", "controllable", "step_seconds"],
  "properties": {
    "ven_id": { "type": "string" },
    "backend": {
      "type": "string",
      "enum": ["energyplus", "virtual", "real_bas"],
      "description": "구현 기술 — common.json §Backend SSOT (여기선 replay 제외)."
    },
    "building_type": {
      "type": "string",
      "enum": ["office_large","office_medium","office_small","hospital","school","retail","convenience_store","apartment","other"],
      "description": "common.json §BuildingType SSOT."
    },
    "idf_path": { "type": "string", "description": "backend=energyplus 시 IDF 경로" },
    "epw_path": { "type": "string", "description": "기상파일(EPW) 경로" },
    "step_seconds": {
      "type": "integer", "minimum": 60, "maximum": 3600,
      "description": "시뮬레이션 타임스텝(초). 60~3600. 제어 반영 지연의 하한."
    },
    "real_time_factor": {
      "type": "number", "minimum": 1, "default": 1,
      "description": "벽시계 대비 배속. 1=실시간, 60=1분 물리시간을 1초에 진행."
    },
    "observable": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/Point" },
      "description": "읽기 가능 포인트. telemetry.json 필드와 대응."
    },
    "controllable": {
      "type": "array",
      "items": { "$ref": "#/$defs/Point" },
      "description": "쓰기 가능 포인트. control_command.json 필드와 대응."
    },
    "supported_strategies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^M[0-8]$" },
      "description": "적용 가능한 EMS 전략 부분집합. 미기재 시 M0 만 지원으로 간주."
    },
    "has_ess": { "type": "boolean", "default": false },
    "has_pv": { "type": "boolean", "default": false },
    "zone_count": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "Point": {
      "type": "object",
      "required": ["key", "unit", "type"],
      "properties": {
        "key": { "type": "string", "description": "텔레메트리/명령 필드명 (예: power_kw, hvac_setpoint)" },
        "unit": { "type": "string", "description": "단위 (예: kW, °C, %, bool)" },
        "type": { "type": "string", "enum": ["number", "boolean", "integer", "string"] },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "e_plus_variable": { "type": "string", "description": "EnergyPlus Variable 명 (선택)" },
        "description": { "type": "string" }
      }
    }
  }
}
