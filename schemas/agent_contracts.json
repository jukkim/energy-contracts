{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/agent_contracts.json",
  "title": "AgentContract SSOT (AI 챔피언 멀티에이전트)",
  "description": "A01~A10 에이전트 입출력 Protocol. building-energy-3d/src/agents/core/contract.py 와 동기. AI 챔피언 본선 카르테 시스템의 단일 진실.",
  "_usage": "codegen",
  "_consumers": [
    "edge-agent",
    "gridbridge",
    "building-energy-3d",
    "agentleague",
    "eduarena"
  ],
  "version": "1.0",
  "updated": "2026-05-17",
  "$comment": "Phase C1 산출물 (myjob/docs/SSOT_GOVERNANCE.md). gen_constants.py 가 이 스키마를 Tier 3 코드로 자동 생성.",
  "$defs": {
    "BuildingContext": {
      "type": "object",
      "description": "에이전트 입력 — 건물 컨텍스트. A01(진단)이 PNU에서 생성, A03/A04/A07 등이 입력으로 받음.",
      "required": [
        "pnu",
        "address",
        "usage_type",
        "gross_area",
        "floors",
        "built_year",
        "structure",
        "eui",
        "energy_tier",
        "energy_grade"
      ],
      "properties": {
        "pnu": {
          "type": "string",
          "description": "법정 PNU 19자리"
        },
        "address": {
          "type": "string"
        },
        "usage_type": {
          "type": "string",
          "description": "건축물대장 용도. constants.py BUILDING_USAGE_MAP 참조"
        },
        "gross_area": {
          "type": "number",
          "description": "연면적 (m²)"
        },
        "floors": {
          "type": "integer"
        },
        "built_year": {
          "type": "integer"
        },
        "structure": {
          "type": "string"
        },
        "eui": {
          "type": "number",
          "description": "Energy Use Intensity (kWh/m²·yr)"
        },
        "energy_tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "data_tier (1=measured, 5=ep_lookup)"
        },
        "energy_grade": {
          "type": "string",
          "description": "1+~7 또는 ZEB 등급"
        },
        "has_kapt": {
          "type": "boolean",
          "default": false
        },
        "has_hourly": {
          "type": "boolean",
          "default": false
        },
        "has_fire_risk": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "AgentResult": {
      "type": "object",
      "description": "에이전트 출력 표준 — 카르테 카드/포트폴리오/SSE에 동일 형식.",
      "required": [
        "agent_name",
        "version",
        "confidence",
        "summary"
      ],
      "properties": {
        "agent_name": {
          "type": "string",
          "description": "예: 'a01_diagnosis'"
        },
        "version": {
          "type": "string",
          "description": "에이전트 버전 (semver)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "결과 신뢰도. 5-Tier 데이터 품질 기반 계산"
        },
        "summary": {
          "type": "string",
          "description": "한 문장 요약 (카드 헤더)"
        },
        "payload": {
          "type": "object",
          "description": "에이전트별 자유 형식 데이터"
        },
        "method_used": {
          "type": "string",
          "description": "사용된 방법 라벨 (예: 'L0_template' / 'L2_llm')"
        },
        "ml_model_version": {
          "type": [
            "string",
            "null"
          ],
          "description": "L1 ML 경로 시 모델 식별자 (예: 'patchtst_v5_168to24'). L0/룰 분기에서는 null."
        },
        "elapsed_sec": {
          "type": "number",
          "minimum": 0,
          "description": "실행 시간 (초)"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "AgentCapability": {
      "type": "string",
      "enum": [
        "diagnosis",
        "forecast",
        "optimization",
        "carbon",
        "safety",
        "renewable",
        "benchmark",
        "market",
        "policy",
        "coordination",
        "dr_orchestration"
      ],
      "description": "A01~A10 핵심 능력 + Phase 4 a11 dr_orchestration"
    },
    "MaturityLevel": {
      "type": "string",
      "enum": [
        "L0_template",
        "L1_rule",
        "L2_llm",
        "L3_optimization"
      ],
      "description": "에이전트 성숙도 (RQ-AI 프레임). L0=정적 템플릿, L1=규칙 기반, L2=LLM, L3=최적화 알고리즘"
    }
  },
  "type": "object",
  "properties": {
    "registry": {
      "type": "object",
      "description": "에이전트 카탈로그 (Phase 1~3: A01~A10, Phase 4+: A11~)",
      "additionalProperties": {
        "type": "object",
        "required": [
          "id",
          "name_en",
          "name_kr",
          "capability",
          "phase"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^a(0[1-9]|1[0-9]|2[0-9])$",
            "description": "a01~a29까지 허용 (Phase 4 a11 dr_orchestrator 도입)"
          },
          "name_en": {
            "type": "string"
          },
          "name_kr": {
            "type": "string"
          },
          "capability": {
            "$ref": "#/$defs/AgentCapability"
          },
          "phase": {
            "type": "integer",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ]
          },
          "maturity": {
            "$ref": "#/$defs/MaturityLevel"
          },
          "requires": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "선행 에이전트 ID (예: A03/A04/A07은 A01 필요)"
          },
          "output_strategies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^M(0[0-9]|1[0-5])$"
            },
            "description": "이 에이전트가 산출할 수 있는 EMS 전략 코드 (Phase H 추가). 비어있으면 전략을 산출하지 않음 (예: 진단·예측·벤치마크)."
          },
          "output_data_source": {
            "$ref": "energy-contracts/data_classification.json#/$defs/DataSource",
            "description": "이 에이전트 결과의 데이터 출처 분류 (Phase H 추가). measured/certified/simulated/predicted/external/synthetic/mock"
          }
        }
      }
    }
  },
  "default": {
    "registry": {
      "a01_diagnosis": {
        "id": "a01",
        "name_en": "Diagnosis",
        "name_kr": "진단",
        "capability": "diagnosis",
        "phase": 1,
        "maturity": "L0_template",
        "requires": [],
        "output_strategies": [],
        "output_data_source": "predicted"
      },
      "a02_forecast": {
        "id": "a02",
        "name_en": "Forecast",
        "name_kr": "예측",
        "capability": "forecast",
        "phase": 2,
        "maturity": "L0_template",
        "requires": [
          "a01"
        ],
        "output_strategies": [],
        "output_data_source": "predicted"
      },
      "a03_optimizer": {
        "id": "a03",
        "name_en": "Optimizer",
        "name_kr": "최적화",
        "capability": "optimization",
