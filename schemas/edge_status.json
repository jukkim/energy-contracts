{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/edge_status.json",
  "title": "EdgeStatus",
  "description": "EdgeAgent heartbeat + 설비·드라이버 상태. Edge → GB (보통 30~60초 주기).",
  "version": "1.1",
  "type": "object",
  "required": ["ven_id", "timestamp", "state", "uptime_sec"],
  "properties": {
    "ven_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "state": {
      "type": "string",
      "enum": ["online", "degraded", "offline", "booting"],
      "description": "online=정상, degraded=일부 드라이버 단절, offline=곧 종료/응답불가, booting=기동중"
    },
    "uptime_sec": { "type": "integer", "minimum": 0 },
    "edge_agent_version": { "type": "string" },
    "queue": {
      "type": "object",
      "description": "로컬 outbox 큐 상태(브로커 단절 내성).",
      "properties": {
        "size": { "type": "integer", "minimum": 0 },
        "oldest_age_sec": { "type": "integer" },
        "max_age_sec": { "type": "integer" }
      }
    },
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "connected"],
        "properties": {
          "name": { "type": "string", "description": "예: virtual, energyplus, bacnet, modbus, replay" },
          "connected": { "type": "boolean" },
          "last_read_at": { "type": "string", "format": "date-time" },
          "last_error": { "type": "string" },
          "points_ok": { "type": "integer", "description": "정상 포인트 수" },
          "points_err": { "type": "integer", "description": "오류 포인트 수" }
        }
      }
    },
    "ems": {
      "type": "object",
      "description": "현재 EMS 실행 상태.",
      "properties": {
        "active_strategy": { "type": "string", "pattern": "^M[0-8]$" },
        "schedule_slot_idx": { "type": "integer" },
        "schedule_id": { "type": "string" },
        "interlocks_fired_1h": { "type": "integer", "minimum": 0 }
      }
    },
    "links": {
      "type": "object",
      "description": "외부 연결 상태.",
      "properties": {
        "mqtt_gb": { "type": "boolean" },
        "mqtt_vw": { "type": "boolean" },
        "ven_vtn": { "type": "boolean", "description": "OpenADR VEN 레거시 경로" }
      }
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{16}$",
      "description": "현재 적용 중인 Edge 설정(YAML 전체)의 SHA256 앞 16자리 16진수. VW/GB 가 중앙 저장된 설정과 비교하여 drift 감지. 미일치 시 VW 측에서 재배포 플로우 트리거. 계산 범위: envelope + connection + data_points + interlocks + supported_strategies (민감정보·타임스탬프 제외)."
    },
    "config_updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Edge 측 설정 파일 마지막 반영 시각. VW 중앙 설정의 updated_at 과 비교하여 신선도 확인."
    }
  }
}
