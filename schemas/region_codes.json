        "type": "object",
        "properties": {
          "sim_id": {
            "type": "string",
            "description": "sim_id 내 2자리 코드"
          },
          "name_en": {
            "type": "string"
          },
          "name_kr": {
            "type": "string"
          },
          "cooling": {
            "type": "string"
          },
          "heating": {
            "type": "string"
          },
          "staging_m03": {
            "type": "boolean"
          },
          "economizer_m02": {
            "type": "boolean"
          }
        }
      }
    }
  },
