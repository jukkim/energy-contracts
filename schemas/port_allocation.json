{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "energy-contracts/port_allocation.json",
  "title": "PortAllocationSSOT",
  "description": "myjob 워크스페이스 전체 포트 할당 SSOT. Tier 1 (myjob/CLAUDE.md Port Allocation) 의 머신리더블 버전. 변경 시 양쪽 동시 갱신 필수.",
  "version": "1.0.0",
  "updated": "2026-05-16",
  "$comment": "SSOT_GOVERNANCE.md Phase A1 산출물. 헬스체크 스크립트·CI 검증·신규 서비스 포트 배정 시 이 파일을 단일 진실로 사용한다.",

  "ranges": {
    "http_api": {
      "range": "8000-8999",
      "description": "HTTP API / 백엔드 서비스"
    },
    "frontend_dev": {
      "range": "3000-3999",
      "description": "Next.js / Vite 개발 서버"
    },
    "vite_hmr": {
      "range": "5170-5199",
      "description": "Vite Hot Module Replacement"
    },
    "postgres": {
      "range": "5432-5499",
      "description": "PostgreSQL 인스턴스"
    },
    "redis": {
      "range": "6379-6399",
      "description": "Redis 인스턴스"
    },
    "mqtt": {
      "range": "1883, 9001",
      "description": "MQTT TCP + WebSocket"
    }
  },

  "machines": {
    "A": {
      "gdrive_root": "H:/내 드라이브",
      "docker_occupied_ports": [8001, 8002],
      "gridbridge_host_port": 8003,
      "note": "호스트 8001/8002는 Docker가 점유. GB는 호스트 8003으로 노출."
    },
    "B": {
      "gdrive_root": "G:/내 드라이브",
      "docker_occupied_ports": [],
      "gridbridge_host_port": 8001,
      "note": "Docker 점유 없음. 코드 기본값 그대로."
    }
  },

  "services": [
    {
      "port": 8000,
      "name": "building-energy-3d API",
      "folder": "projects/building-energy-3d/",
      "purpose": "VWorld 메인 백엔드 (FastAPI)",
      "status": "deployed",
      "env_var": null
